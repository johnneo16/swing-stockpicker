# SwingPro Environment Configuration
# Copy this to .env and fill in your Angel One SmartAPI credentials

# ============================================================
# DATA PROVIDER: 'angelone' or 'yahoo' (default: yahoo)
# ============================================================
DATA_PROVIDER=yahoo

# ============================================================
# ANGEL ONE SMARTAPI CREDENTIALS
# Get these from: https://smartapi.angelone.in/
# ============================================================
ANGELONE_API_KEY=
ANGELONE_CLIENT_ID=
ANGELONE_PASSWORD=
ANGELONE_TOTP_SECRET=

# ============================================================
# PORTFOLIO SETTINGS (optional)
# ============================================================
# TOTAL_CAPITAL=50000
# MAX_RISK_PERCENT=0.02
